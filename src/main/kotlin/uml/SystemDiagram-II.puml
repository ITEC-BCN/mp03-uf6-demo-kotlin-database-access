@startuml
allowmixing

left to right direction

title Arquitectura Completa MVC + DAO (Fallback & Sync)

actor "Usuari" as User

package "View" {
    class TerminalView {
        +mostrarMenuPrincipal(controller: UsuariController)
        --
        -mostrarUsuaris(controller: UsuariController)
        -upsertUsuari(controller: UsuariController)
        -modificarUsuari(controller: UsuariController)
        -eliminarUsuari(controller: UsuariController)
        -esborrarLlista(controller: UsuariController)
    }
}

package "Controller" {
    class UsuariController {
        -usuariDao: IUsuariDao
        --
        +UsuariController(dao: IUsuariDao)
        +getUsuaris() : List<Usuari>
        +idsUsuari() : List<Int>
        +getUsuariById(id: Int) : Usuari?
        +inserirUsuari(u: Usuari) : Int
        +modificarUsuari(u: Usuari) : Int
        +eliminarUsuari(u: Usuari) : Int
        +eliminarLlista() : Int
    }
}

package "Model" {
    class Usuari {
        -id : Int
        -nom : String
        -nivell : NivellUsuari
        --
        +Usuari(id: Int, nom: String, nivell: NivellUsuari)
        +getId(): Int
        +getNom(): String
        +getNivell(): NivellUsuari
        +toString(): String
    }

    enum NivellUsuari {
        DOCENT, COORDINADOR, DIRECTIU
        --
        +fromString(valor: String): NivellUsuari
    }
}

package "DAO" {
    interface IUsuariDao <<interface>> {
        +getAllUsers() : List<Usuari>
        +getUserIdList() : List<Int>
        +getUserById(id: Int) : Usuari?
        +insertUser(u: Usuari) : Int
        +updateUser(u: Usuari) : Int
        +deleteUser(u: Usuari) : Int
        +deleteAll() : Int
    }

    class UsuariDao {
        -databaseConnection: Connection
        --
        +UsuariDao(c: Connection)
        +getAllUsers() : List<Usuari>
        +getUserIdList() : List<Int>
        +getUserById(id: Int) : Usuari?
        +insertUser(u: Usuari) : Int
        +updateUser(u: Usuari) : Int
        +deleteUser(u: Usuari) : Int
        +deleteAll() : Int
    }
}

package "Database" {

    class ConnectionManager << (O, #A9E4FF) >> {
        -connection : Connection
        -isCloud : Boolean
        --
        +getConnection() : Connection
        +isUsingCloud() : Boolean
    }

    class DBSyncManager << (O, #A9E4FF) >> {
        +syncDatabases()
    }

    class DatabaseManager << (O, #A9E4FF) >> {
        -DATABASE_FILE: String
        +getConn(): Connection
    }

    class SupabaseManager << (O, #A9E4FF) >> {
        -URL: String
        -USER: String
        -PASS: String
        -PORT: String
        - connection: Connection
        --
        +getConn() : Connection
    }
}

database "SQLite (.db)" as SQLite
database "Supabase (Postgres)" as Supabase
file "secrets.properties" as secrets

' Relacions
User --> TerminalView : interactua
TerminalView --> UsuariController : crida accions
UsuariController o-- IUsuariDao : injecció (rebut per constructor)

UsuariDao ..|> IUsuariDao : implementa
UsuariDao --> Usuari : crea
Usuari "n" *-- "1" NivellUsuari : és

' La injecció de la connexió al DAO
UsuariDao o-- "ConnectionManager" : rep per injecció

DatabaseManager --> SQLite
SupabaseManager --> Supabase
SupabaseManager ..> secrets : llegeix dades

ConnectionManager --> SupabaseManager : demana connexió remot
ConnectionManager --> DatabaseManager : demana connexió local
DBSyncManager ..> ConnectionManager : usa per obtenir l'estat actual
DBSyncManager ..> UsuariDao : usa instàncies (local/remot) per sincronitzar

' El Main (implícit) usaria el ConnectionManager per crear el DAO
' que després s'injecta al Controller.
@enduml